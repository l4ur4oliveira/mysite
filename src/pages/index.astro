---
import "../styles/global.css";
import * as Hero from '../content/hero.md';
import * as AboutWork from '../content/about-and-work.md';
import * as Skills from '../content/skills.md';

import { marked } from "marked";

import ChatCircleDots from 'phosphor-astro/ChatCircleDots.astro';
import Clock from 'phosphor-astro/Clock.astro';
import Code from 'phosphor-astro/Code.astro';
import FigmaLogo from 'phosphor-astro/FigmaLogo.astro';
import FileJs from 'phosphor-astro/FileJs.astro';
import GitBranch from 'phosphor-astro/GitBranch.astro';
import Layout from 'phosphor-astro/Layout.astro';
import Kanban from 'phosphor-astro/Kanban.astro';
import Palette from 'phosphor-astro/Palette.astro';
import PresentationChart from 'phosphor-astro/PresentationChart.astro';
import TrendUp from 'phosphor-astro/TrendUp.astro';
import Users from 'phosphor-astro/Users.astro';

const iconMap = {
	Users,
	ChatCircleDots,
	TrendUp,
	Kanban,
	Clock,
	PresentationChart,
	Code,
	GitBranch,
	FileJs,
	FigmaLogo,
	Palette,
	Layout
};

const aboutWorkContent = AboutWork.rawContent().split('<!-- split -->');
const workContent = marked(aboutWorkContent[0]);
const rolesContent = marked(aboutWorkContent[1]);
const educationContent = marked(aboutWorkContent[2]);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/olive-leaf.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Laura de Oliveira</title>
	</head>
	<body>
		<nav class="fixed top-0 left-0 right-0 z-50 bg-black">
			<div class="max-w-6xl m-auto py-6 flex items-center justify-between">
				<a href="#hero" class="flex items-center gap-3">
					<img src="/logo-lauoliveira.svg" alt="Logo Laura" class="max-w-[180px] w-full mx-auto" />
				</a>
				<ul class="flex items-center gap-9 font-oxygen-mono text-lime-400">
					<li><a href="#about" class="tracking-tighter hover:underline">Trabalho</a></li>
					<li><a href="#skills" class="tracking-tighter hover:underline">Skills</a></li>
					<li><a href="#contact" class="tracking-tighter hover:underline">Contato</a></li>
				</ul>
			</div>
		</nav>
		<main class="w-full">
			<section id="hero" class="bg-white">
				<div class="max-w-6xl m-auto py-10 pt-40 flex flex-col md:flex-row items-center justify-center gap-40">
					<div class="w-full px-6 md:w-4/6 md:px-0 flex flex-col gap-10">
						<h1 class="text-7xl font-oxygen-mono tracking-tighter">
							Hi, I'm <span class="text-lime-400">Laura</span>.
						</h1>
						<div class="leading-7">
							<Hero.Content />
						</div>
					</div>
					<div class="w-full md:w-2/6">
						<img src={Hero.frontmatter.photoUrl} alt={Hero.frontmatter.photoAlt} class="max-w-[350px] m-auto rounded-full" />
					</div>
				</div>
			</section>
			<section id="about" class="bg-white">
				<div class="max-w-6xl m-auto py-10 pb-20 flex flex-col gap-10">
					<div>
						<h2 class="text-4xl font-oxygen-mono text-teal-800 mb-10">{AboutWork.frontmatter.workTitle}</h2>
						<div class="leading-7" set:html={workContent}></div>
					</div>
					<div class="w-full flex">
						<div class="w-1/2 leading-7" set:html={rolesContent}></div>
						<div class="w-1/2 leading-7" set:html={educationContent}></div>
					</div>
				</div>
			</section>
			<section id="skills" class="bg-teal-50">
				<div class="max-w-6xl m-auto py-20">
					<h2 class="text-4xl font-oxygen-mono text-teal-800 mb-10">{Skills.frontmatter.workTitle}</h2>
					<div class="w-full">
						<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 items-stretch">
							{Skills.frontmatter.skills.map((skill) => (
								<article class="flex flex-col justify-between h-full rounded-lg bg-white shadow-md p-6 transform hover:scale-105 hover:shadow-lg transition-transform duration-200">
									<div>
										<h3 class="mb-2 text-lg font-semibold text-teal-800">{skill.name}</h3>
										<p class="text-teal-800 leading-7">{skill.description}</p>
									</div>
									<div class="mt-6 flex items-center gap-3">
										{(skill.icons || []).slice(0,3).map((iconName) => {
											const Icon = iconMap[iconName];

											return Icon && (
												<Icon weight="bold" class="w-8 h-8 p-2 rounded-md bg-lime-400 text-teal-800" />
											);
										})}
									</div>
								</article>
							))}
						</div>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>
