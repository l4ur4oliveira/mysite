---
import "../styles/global.css";
import * as Hero from '../content/hero.md';
import * as AboutWork from '../content/about-and-work.md';
import * as Skills from '../content/skills.md';

import { marked } from "marked";

import CaretDoubleDown from 'phosphor-astro/CaretDoubleDown.astro';
import { formatDateShort } from '../lib/format-date.js';

import ChatCircleDots from 'phosphor-astro/ChatCircleDots.astro';
import Clock from 'phosphor-astro/Clock.astro';
import Code from 'phosphor-astro/Code.astro';
import FigmaLogo from 'phosphor-astro/FigmaLogo.astro';
import FileJs from 'phosphor-astro/FileJs.astro';
import GitBranch from 'phosphor-astro/GitBranch.astro';
import Layout from 'phosphor-astro/Layout.astro';
import Kanban from 'phosphor-astro/Kanban.astro';
import Palette from 'phosphor-astro/Palette.astro';
import PresentationChart from 'phosphor-astro/PresentationChart.astro';
import TrendUp from 'phosphor-astro/TrendUp.astro';
import Users from 'phosphor-astro/Users.astro';
import EnvelopeSimple from 'phosphor-astro/EnvelopeSimple.astro';
import GithubLogo from 'phosphor-astro/GithubLogo.astro';
import LinkedinLogo from 'phosphor-astro/LinkedinLogo.astro';
import Sun from 'phosphor-astro/Sun.astro';
import Moon from 'phosphor-astro/Moon.astro';

import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';

const iconMap = {
	Users,
	ChatCircleDots,
	TrendUp,
	Kanban,
	Clock,
	PresentationChart,
	Code,
	GitBranch,
	FileJs,
	FigmaLogo,
	Palette,
	Layout
};

const aboutWorkContent = AboutWork.rawContent().split('<!-- split -->');
const workContent = marked(aboutWorkContent[0]);
const rolesContent = marked(aboutWorkContent[1]);
const educationContent = marked(aboutWorkContent[2]);

const allPosts = (await Astro.glob('../content/posts/*.md'))
	.sort((a, b) => b.frontmatter.date.localeCompare(a.frontmatter.date));

const posts = allPosts.map((post, i) => {
	const slug = post.file.split('/').pop().replace('.md', '');
	return { post, index: i, hidden: i >= 6, slug };
});

const grouped = {};
posts.forEach(p => {
	const year = p.post.frontmatter.date.split('-')[0];
	if (!grouped[year]) grouped[year] = [];
	grouped[year].push(p);
});
const years = Object.keys(grouped).sort((a, b) => b.localeCompare(a));
const hasHidden = posts.some(p => p.hidden);
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/olive-leaf.svg" />
		<meta name="viewport" content="width=device-width" />
		<SEO />
		<Analytics />
		<script is:inline>
			if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body class="bg-white dark:bg-teal-950 text-teal-950 dark:text-teal-300">
		<nav class="fixed top-0 left-0 right-0 z-50 bg-black">
			<div class="max-w-6xl m-auto px-6 py-6 flex items-center justify-between">
				<a href="#hero" class="flex items-center gap-3">
					<img src="/logo-lauoliveira.svg" alt="Logo Laura" class="max-w-[180px] w-full mx-auto" />
				</a>
				<!-- Desktop links -->
				<div class="hidden md:flex items-center gap-4 text-lime-400">
					<ul class="flex items-center gap-9 font-oxygen-mono">
						<li><a href="#about" class="tracking-tighter hover:underline underline-offset-2">{AboutWork.frontmatter.title}</a></li>
						<li><a href="#skills" class="tracking-tighter hover:underline underline-offset-2">{Skills.frontmatter.title}</a></li>
						<li><a href="#posts" class="tracking-tighter hover:underline underline-offset-2">Posts</a></li>
						<li><a href="#contact" class="tracking-tighter hover:underline underline-offset-2">Contato</a></li>
					</ul>
					<button id="theme-toggle-desktop" class="p-2 ml-4 hover:text-white transition-colors outline-none cursor-pointer" aria-label="Toggle theme">
						<Sun class="w-6 h-6 hidden dark:block" />
						<Moon class="w-6 h-6 block dark:hidden" />
					</button>
				</div>
			</div>
			<!-- Mobile hidden checkbox controls menu and hamburger state -->
			<input id="nav-toggle" type="checkbox" class="peer sr-only" />
			<!-- Mobile hamburger menu -->
			<label for="nav-toggle" class="md:hidden absolute right-16 top-6 cursor-pointer p-2 z-50" aria-label="Alternar menu de navegação">
				<span class="bar1 block w-6 h-0.5 bg-lime-400 mb-1" aria-hidden="true"></span>
				<span class="bar2 block w-6 h-0.5 bg-lime-400 mb-1" aria-hidden="true"></span>
				<span class="bar3 block w-6 h-0.5 bg-lime-400" aria-hidden="true"></span>
			</label>
			<ul id="mobile-menu" class="hidden peer-checked:flex md:hidden flex-col gap-2 px-6 pb-4 pt-2 bg-black text-lime-400 font-oxygen-mono">
				<li><a href="#about" class="block py-2 hover:underline">{AboutWork.frontmatter.title}</a></li>
				<li><a href="#skills" class="block py-2 hover:underline">{Skills.frontmatter.title}</a></li>
				<li><a href="#posts" class="block py-2 hover:underline">Posts</a></li>
				<li><a href="#contact" class="block py-2 hover:underline">Contato</a></li>
			</ul>
			<button id="theme-toggle-mobile" class="md:hidden absolute right-4 top-5 cursor-pointer p-2 z-50 text-lime-400 hover:text-white transition-colors outline-none" aria-label="Toggle theme">
				<Sun class="w-6 h-6 hidden dark:block" />
				<Moon class="w-6 h-6 block dark:hidden" />
			</button>
		</nav>
		<main class="w-full">
			<section id="hero" class="bg-white dark:bg-teal-950 transition-colors duration-300">
				<div class="max-w-6xl m-auto px-6 py-10 pt-36 md:pt-40 flex flex-col-reverse md:flex-row items-center justify-between gap-10 md:gap-16">
					<div class="w-full md:flex-1 flex flex-col gap-8 md:gap-10">
						<h1 class="text-5xl md:text-6xl lg:text-7xl font-oxygen-mono tracking-tighter dark:text-white transition-colors duration-300">
							Hi, I'm <span class="text-lime-400">Laura</span>.
						</h1>
						<div class="leading-7">
							<Hero.Content />
						</div>
					</div>
					<div class="avatar w-auto relative rounded-full">
						<img src={Hero.frontmatter.photoUrl} alt={Hero.frontmatter.photoAlt} class="max-w-[200px] md:max-w-[300px] lg:max-w-[350px] m-auto rounded-full relative z-2" />
					</div>
				</div>
			</section>
			<section id="about" class="bg-white dark:bg-teal-950 transition-colors duration-300">
				<div class="max-w-6xl m-auto px-6 py-10 pb-20 flex flex-col gap-10">
					<div>
						<h2 class="text-4xl font-oxygen-mono text-teal-800 dark:text-lime-400 mb-10 transition-colors duration-300">{AboutWork.frontmatter.title}</h2>
						<div class="leading-7" set:html={workContent}></div>
					</div>
					<div class="w-full flex flex-col md:flex-row gap-8 md:gap-12 lg:gap-20">
						<div class="md:flex-1 leading-7" set:html={rolesContent}></div>
						<div class="md:flex-1 leading-7" set:html={educationContent}></div>
					</div>
					<div class="flex">
						<a href="/resume" class="w-full md:w-auto flex items-center justify-center px-6 py-3 rounded-md shadow-md bg-lime-400 text-teal-800 hover:bg-teal-800 hover:text-lime-400 font-oxygen-mono transform hover:scale-105 transition-transform duration-200">
							Ver currículo completo
						</a>
					</div>
				</div>
			</section>
			<section id="skills" class="bg-teal-50 dark:bg-teal-900 transition-colors duration-300">
				<div class="max-w-6xl m-auto px-6 py-10 md:py-20">
					<h2 class="text-4xl font-oxygen-mono text-teal-800 dark:text-lime-400 mb-10 transition-colors duration-300">{Skills.frontmatter.title}</h2>
					<div class="w-full">
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
							{Skills.frontmatter.skills.map((skill) => (
								<article class="flex flex-col justify-between h-full rounded-lg bg-white dark:bg-teal-700 shadow-md p-6 transform hover:scale-105 hover:shadow-lg transition-transform duration-200 transition-colors">
									<div>
										<h3 class="mb-2 text-lg font-semibold text-teal-800 dark:text-lime-400">{skill.name}</h3>
										<p class="text-teal-800 dark:text-teal-300 leading-7">{skill.description}</p>
									</div>
									<div class="mt-6 flex items-center gap-3">
										{(skill.icons || []).slice(0,3).map((iconName) => {
											const Icon = iconMap[iconName];

											return Icon && (
												<Icon weight="bold" class="w-8 h-8 p-2 rounded-md bg-lime-400 text-teal-800" />
											);
										})}
									</div>
								</article>
							))}
						</div>
					</div>
				</div>
			</section>
			<section id="posts" class="bg-white dark:bg-teal-950 transition-colors duration-300">
				<div class="max-w-6xl m-auto px-6 py-10 md:py-20">
					<h2 class="text-4xl font-oxygen-mono text-teal-800 dark:text-lime-400 mb-4 transition-colors duration-300">Posts</h2>
					<p class="text-teal-800 dark:text-teal-300 mb-10 leading-7 transition-colors duration-300">
						Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
					</p>
					<div id="posts-list">
						{years.map(year => {
							const yearAllHidden = grouped[year].every(({ hidden }) => hidden);
							return (
							<div class:list={{ 'mb-8 last:mb-0': true, 'hidden-post': yearAllHidden }}>
								<h3 class="text-2xl font-oxygen-mono text-teal-800 dark:text-lime-400 mb-4 transition-colors duration-300">{year}</h3>
								<ul class="space-y-3">
									{grouped[year].map(({ post, hidden, slug }) => (
										<li class:list={{ 'hidden-post': hidden }} class="flex items-baseline gap-6">
											<span class="inline-block w-[6ch] font-oxygen-mono text-sm text-teal-600 dark:text-teal-400 whitespace-nowrap">{formatDateShort(post.frontmatter.date)}</span>
											<a href={`/posts/${slug}`} class="text-teal-800 dark:text-teal-200 hover:text-lime-400 dark:hover:text-lime-400 transition-colors underline-offset-2 hover:underline">
												{post.frontmatter.title}
											</a>
										</li>
									))}
								</ul>
							</div>
							);
						})}
					</div>
					{hasHidden && (
						<div class="flex justify-center mt-8">
							<button id="posts-toggle" class="cursor-pointer text-teal-600 dark:text-teal-400 hover:text-lime-400 dark:hover:text-lime-400 transition-colors p-2 outline-none" aria-label="Mostrar mais posts">
								<CaretDoubleDown id="posts-toggle-icon" class="w-8 h-8 transition-transform duration-300" />
							</button>
						</div>
					)}
				</div>
			</section>
			<section id="contact" class="bg-teal-50 dark:bg-teal-900 transition-colors duration-300">
				<div class="max-w-6xl m-auto px-6 py-20">
					<h2 class="text-4xl font-oxygen-mono text-teal-800 dark:text-lime-400 mb-6 transition-colors duration-300">Entre em contato</h2>
					<p class="text-teal-800 dark:text-teal-300 mb-8 transition-colors duration-300">Aberta a novas conexões, parcerias e oportunidades. Entre em contato e vamos construir algo juntos.</p>
					<div class="flex flex-col md:flex-row items-center md:items-start gap-4">
						<a href="https://www.linkedin.com/in/l4ur4oliveira/" target="_blank" rel="noopener noreferrer" class="w-full md:w-auto flex items-center justify-center gap-3 px-4 py-3 rounded-md shadow-md hover:bg-lime-400 dark:hover:bg-lime-400 dark:bg-teal-800 text-teal-800 dark:text-teal-100 dark:hover:text-teal-800 transform hover:scale-105 transition-all duration-200">
							<LinkedinLogo class="w-6 h-6" />
							<span class="font-oxygen-mono">LinkedIn</span>
						</a>
						<a href="https://github.com/l4ur4oliveira" target="_blank" rel="noopener noreferrer" class="w-full md:w-auto flex items-center justify-center gap-3 px-4 py-3 rounded-md shadow-md hover:bg-lime-400 dark:hover:bg-lime-400 dark:bg-teal-800 text-teal-800 dark:text-teal-100 dark:hover:text-teal-800 transform hover:scale-105 transition-all duration-200">
							<GithubLogo class="w-6 h-6" />
							<span class="font-oxygen-mono">GitHub</span>
						</a>
						<a href="mailto:l4ur4.88@gmail.com" class="w-full md:w-auto flex items-center justify-center gap-3 px-4 py-3 rounded-md shadow-md hover:bg-lime-400 dark:hover:bg-lime-400 dark:bg-teal-800 text-teal-800 dark:text-teal-100 dark:hover:text-teal-800 transform hover:scale-105 transition-all duration-200">
							<EnvelopeSimple class="w-6 h-6" />
							<span class="font-oxygen-mono">Email</span>
						</a>
					</div>
				</div>
			</section>
			<footer class="bg-black">
				<div class="max-w-6xl m-auto px-6 py-6 text-center font-oxygen-mono">
					<div class="text-lime-400 flex items-center justify-center gap-2">
						<span>&copy; {new Date().getFullYear()}</span>
						<span class="inline-block w-5 h-5" style="-webkit-mask: url('/olive-leaf.svg') no-repeat center/contain; mask: url('/olive-leaf.svg') no-repeat center/contain; background-color: currentColor;" aria-hidden="true"></span>
						<span>l4uOliveira</span>
					</div>
				</div>
			</footer>
		</main>
		<script>
			const handleToggleClick = () => {
				const element = document.documentElement;
				element.classList.toggle("dark");
			}

			document.getElementById("theme-toggle-desktop")?.addEventListener("click", handleToggleClick);
			document.getElementById("theme-toggle-mobile")?.addEventListener("click", handleToggleClick);

			// Automatically adapt to OS changes dynamically
			window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
				if (e.matches) {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			});

			// Close mobile checkbox menu
			(function(){
				const toggle = document.getElementById('nav-toggle');
				if (!toggle) return;

				const menuLinks = document.querySelectorAll('a[href^="#"]');
				menuLinks.forEach(link => link.addEventListener('click', () => { if (toggle.checked) toggle.checked = false; }));
				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && toggle.checked) toggle.checked = false;
				});
			})();

			// Expand/collapse posts
			document.getElementById('posts-toggle')?.addEventListener('click', () => {
				document.getElementById('posts-list')?.classList.toggle('posts-expanded');
				document.getElementById('posts-toggle-icon')?.classList.toggle('rotate-180');
			});
		</script>
	</body>
</html>
