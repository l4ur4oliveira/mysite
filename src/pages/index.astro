---
import "../styles/global.css";
import * as Hero from '../content/hero.md';
import * as AboutWork from '../content/about-and-work.md';

import { marked } from "marked";

const aboutWorkContent = AboutWork.rawContent().split('<!-- split -->');
const aboutContent = marked(aboutWorkContent[0]);
const workContent = marked(aboutWorkContent[1]);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/olive-leaf.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Laura de Oliveira</title>
	</head>
	<body>
		<main class="w-full">
			<section id="hero" class="bg-white">
				<div class="max-w-7xl m-auto py-28 flex flex-col md:flex-row items-center justify-center gap-40">
					<div class="w-full px-6 md:w-4/6 md:px-0 flex flex-col gap-10">
						<h1 class="text-8xl font-oxygen-mono tracking-tighter">
							Hi, I'm <span class="text-lime-400">Laura</span>.
						</h1>
						<div class="leading-7">
							<Hero.Content />
						</div>
					</div>
					<div class="w-full md:w-2/6">
						<img src={Hero.frontmatter.photoUrl} alt={Hero.frontmatter.photoAlt} class="max-w-[350px] m-auto rounded-full" />
					</div>
				</div>
			</section>
			<section id="about" class="bg-teal-50">
				<div class="max-w-7xl m-auto py-10 flex flex-col md:flex-row gap-20">
					<div class="w-full px-6 md:w-1/2 md:px-0">
						<h2 class="text-4xl font-oxygen-mono text-teal-800 mb-10">{AboutWork.frontmatter.aboutTitle}</h2>
						<div class="leading-7" set:html={aboutContent}></div>
					</div>
					<div class="w-full px-6 md:w-1/2 md:px-0">
						<h2 class="text-4xl font-oxygen-mono text-teal-800 mb-10">{AboutWork.frontmatter.workTitle}</h2>
						<div class="leading-7" set:html={workContent}></div>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>
