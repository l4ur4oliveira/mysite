---
import "../styles/global.css";
import * as Hero from '../content/hero.md';
import * as AboutWork from '../content/about-and-work.md';
import * as Skills from '../content/skills.md';

import { marked } from "marked";

import ChatCircleDots from 'phosphor-astro/ChatCircleDots.astro';
import Clock from 'phosphor-astro/Clock.astro';
import Code from 'phosphor-astro/Code.astro';
import FigmaLogo from 'phosphor-astro/FigmaLogo.astro';
import FileJs from 'phosphor-astro/FileJs.astro';
import GitBranch from 'phosphor-astro/GitBranch.astro';
import Layout from 'phosphor-astro/Layout.astro';
import Kanban from 'phosphor-astro/Kanban.astro';
import Palette from 'phosphor-astro/Palette.astro';
import PresentationChart from 'phosphor-astro/PresentationChart.astro';
import TrendUp from 'phosphor-astro/TrendUp.astro';
import Users from 'phosphor-astro/Users.astro';
import EnvelopeSimple from 'phosphor-astro/EnvelopeSimple.astro';
import GithubLogo from 'phosphor-astro/GithubLogo.astro';
import LinkedinLogo from 'phosphor-astro/LinkedinLogo.astro';

import Analytics from '@vercel/analytics/astro';

const iconMap = {
	Users,
	ChatCircleDots,
	TrendUp,
	Kanban,
	Clock,
	PresentationChart,
	Code,
	GitBranch,
	FileJs,
	FigmaLogo,
	Palette,
	Layout
};

const aboutWorkContent = AboutWork.rawContent().split('<!-- split -->');
const workContent = marked(aboutWorkContent[0]);
const rolesContent = marked(aboutWorkContent[1]);
const educationContent = marked(aboutWorkContent[2]);
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/olive-leaf.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Laura de Oliveira</title>
		<Analytics />
	</head>
	<body>
		<nav class="fixed top-0 left-0 right-0 z-50 bg-black">
			<div class="max-w-6xl m-auto px-6 md:px-0 py-6 flex items-center justify-between">
				<a href="#hero" class="flex items-center gap-3">
					<img src="/logo-lauoliveira.svg" alt="Logo Laura" class="max-w-[180px] w-full mx-auto" />
				</a>
				<!-- Desktop links -->
				<ul class="hidden md:flex items-center gap-9 font-oxygen-mono text-lime-400">
					<li><a href="#about" class="tracking-tighter hover:underline underline-offset-2">Trabalho</a></li>
					<li><a href="#skills" class="tracking-tighter hover:underline underline-offset-2">Skills</a></li>
					<li><a href="#contact" class="tracking-tighter hover:underline underline-offset-2">Contato</a></li>
				</ul>
			</div>
			<!-- Mobile hidden checkbox controls menu and hamburger state -->
			<input id="nav-toggle" type="checkbox" class="peer sr-only" />
			<!-- Mobile hamburger menu -->
			<label for="nav-toggle" class="md:hidden absolute right-6 top-6 cursor-pointer p-2 z-50" aria-label="Alternar menu de navegação">
				<span class="bar1 block w-6 h-0.5 bg-lime-400 mb-1" aria-hidden="true"></span>
				<span class="bar2 block w-6 h-0.5 bg-lime-400 mb-1" aria-hidden="true"></span>
				<span class="bar3 block w-6 h-0.5 bg-lime-400" aria-hidden="true"></span>
			</label>
			<ul id="mobile-menu" class="hidden peer-checked:flex md:hidden flex-col gap-2 px-6 pb-4 pt-2 bg-black text-lime-400 font-oxygen-mono">
				<li><a href="#about" class="block py-2 hover:underline">Trabalho</a></li>
				<li><a href="#skills" class="block py-2 hover:underline">Skills</a></li>
				<li><a href="#contact" class="block py-2 hover:underline">Contato</a></li>
			</ul>
		</nav>
		<main class="w-full">
			<section id="hero" class="bg-white">
				<div class="max-w-6xl m-auto py-10 pt-36 md:pt-40 flex flex-col-reverse md:flex-row items-center justify-center gap-10 md:gap-40">
					<div class="w-full px-6 md:w-4/6 md:px-0 flex flex-col gap-10">
						<h1 class="text-5xl md:text-7xl font-oxygen-mono tracking-tighter">
							Hi, I'm <span class="text-lime-400">Laura</span>.
						</h1>
						<div class="leading-7">
							<Hero.Content />
						</div>
					</div>
					<div class="avatar w-auto md:w-2/6 relative rounded-full">
						<img src={Hero.frontmatter.photoUrl} alt={Hero.frontmatter.photoAlt} class="max-w-[200px] md:max-w-[350px] m-auto rounded-full relative z-2" />
					</div>
				</div>
			</section>
			<section id="about" class="bg-white">
				<div class="max-w-6xl m-auto py-10 pb-20 px-6 md:px-0 flex flex-col gap-10">
					<div>
						<h2 class="text-4xl font-oxygen-mono text-teal-800 mb-10">{AboutWork.frontmatter.workTitle}</h2>
						<div class="leading-7" set:html={workContent}></div>
					</div>
					<div class="w-full flex flex-col md:flex-row gap-4 md:gap-0">
						<div class="md:w-1/2 leading-7" set:html={rolesContent}></div>
						<div class="md:w-1/2 leading-7" set:html={educationContent}></div>
					</div>
				</div>
			</section>
			<section id="skills" class="bg-teal-50">
				<div class="max-w-6xl m-auto py-10 px-6 md:px-0 md:py-20">
					<h2 class="text-4xl font-oxygen-mono text-teal-800 mb-10">{Skills.frontmatter.workTitle}</h2>
					<div class="w-full">
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
							{Skills.frontmatter.skills.map((skill) => (
								<article class="flex flex-col justify-between h-full rounded-lg bg-white shadow-md p-6 transform hover:scale-105 hover:shadow-lg transition-transform duration-200">
									<div>
										<h3 class="mb-2 text-lg font-semibold text-teal-800">{skill.name}</h3>
										<p class="text-teal-800 leading-7">{skill.description}</p>
									</div>
									<div class="mt-6 flex items-center gap-3">
										{(skill.icons || []).slice(0,3).map((iconName) => {
											const Icon = iconMap[iconName];

											return Icon && (
												<Icon weight="bold" class="w-8 h-8 p-2 rounded-md bg-lime-400 text-teal-800" />
											);
										})}
									</div>
								</article>
							))}
						</div>
					</div>
				</div>
			</section>
			<section id="contact" class="bg-white">
				<div class="max-w-6xl m-auto py-20 px-6 md:px-0">
					<h2 class="text-4xl font-oxygen-mono text-teal-800 mb-6">Entre em contato</h2>
					<p class="text-teal-800 mb-8">Aberta a novas conexões, parcerias e oportunidades. Entre em contato e vamos construir algo juntos.</p>
					<div class="flex flex-col md:flex-row items-center md:items-start gap-4">
						<a href="https://www.linkedin.com/in/l4ur4oliveira/" target="_blank" rel="noopener noreferrer" class="w-full md:w-auto flex items-center justify-center gap-3 px-4 py-3 rounded-md shadow-md hover:bg-lime-400 transform hover:scale-105 transition-transform duration-200">
							<LinkedinLogo class="w-6 h-6 text-teal-800" />
							<span class="font-oxygen-mono text-teal-800">LinkedIn</span>
						</a>
						<a href="https://github.com/l4ur4oliveira" target="_blank" rel="noopener noreferrer" class="w-full md:w-auto flex items-center justify-center gap-3 px-4 py-3 rounded-md shadow-md hover:bg-lime-400 transform hover:scale-105 transition-transform duration-200">
							<GithubLogo class="w-6 h-6 text-teal-800" />
							<span class="font-oxygen-mono text-teal-800">GitHub</span>
						</a>
						<a href="mailto:l4ur4.88@gmail.com" class="w-full md:w-auto flex items-center justify-center gap-3 px-4 py-3 rounded-md shadow-md hover:bg-lime-400 transform hover:scale-105 transition-transform duration-200">
							<EnvelopeSimple class="w-6 h-6 text-teal-800" />
							<span class="font-oxygen-mono text-teal-800">Email</span>
						</a>
					</div>
				</div>
			</section>
			<footer class="bg-black">
				<div class="max-w-6xl m-auto py-6 text-center font-oxygen-mono">
					<div class="text-lime-400 flex items-center justify-center gap-2">
						<span>&copy; {new Date().getFullYear()}</span>
						<span class="inline-block w-5 h-5" style="-webkit-mask: url('/olive-leaf.svg') no-repeat center/contain; mask: url('/olive-leaf.svg') no-repeat center/contain; background-color: currentColor;" aria-hidden="true"></span>
						<span>l4uOliveira</span>
					</div>
				</div>
			</footer>
		</main>
		<script>
			// Close mobile checkbox menu
			(function(){
				const toggle = document.getElementById('nav-toggle');
				if (!toggle) return;

				const menuLinks = document.querySelectorAll('a[href^="#"]');
				menuLinks.forEach(link => link.addEventListener('click', () => { if (toggle.checked) toggle.checked = false; }));
				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && toggle.checked) toggle.checked = false;
				});
			})();
		</script>
	</body>
</html>
