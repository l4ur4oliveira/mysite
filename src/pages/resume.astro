---
import "../styles/global.css";
import * as MyResume from '../content/resume.md';

import SEO from '../components/SEO.astro';
import Navbar from '../components/Navbar.astro';

import Analytics from '@vercel/analytics/astro';

import DownloadSimple from 'phosphor-astro/DownloadSimple.astro';
import EnvelopeSimple from "phosphor-astro/EnvelopeSimple.astro";
import GithubLogo from 'phosphor-astro/GithubLogo.astro';
import Globe from 'phosphor-astro/Globe.astro';
import LinkedinLogo from 'phosphor-astro/LinkedinLogo.astro';
import MapPin from 'phosphor-astro/MapPin.astro';

const iconMap = {
	EnvelopeSimple,
	GithubLogo,
	Globe,
	LinkedinLogo,
	MapPin,
};
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/olive-leaf.svg" />
		<meta name="viewport" content="width=device-width" />
		<SEO title="Laura de Oliveira | Résumé" />
		<Analytics />
		<script is:inline>
			if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body class="bg-teal-50 dark:bg-teal-950 text-teal-950 dark:text-teal-300">
		<Navbar printHidden />
		<main class="w-full">
			<section class="max-w-4xl m-auto pt-24 md:pt-32 print:pt-0 px-4 md:px-0 mb-16 print:mb-0 transition-colors duration-300">
				<div class="bg-white dark:bg-teal-900 shadow-xl print:shadow-none rounded-lg p-8 md:p-16 print:p-10 transition-colors duration-300">
					<h1 class="text-5xl md:text-6xl font-oxygen-mono text-teal-800 dark:text-lime-400 tracking-tighter mb-5 transition-colors duration-300">Laura de Oliveira</h1>

					<ul class="flex flex-col gap-2 text-sm">
						{
							MyResume.frontmatter.details.map((item: { text: string; url?: string; icon: string }) => {
								const IconCall = iconMap[item.icon];
								return (
									<li class="flex items-center gap-2">
										{IconCall && <IconCall class="w-5 h-5 text-teal-800 dark:text-teal-100" />}
										{item.url ? (
											<a href={item.url} target="_blank" rel="noopener noreferrer" class="text-teal-800 dark:text-teal-100 hover:text-lime-400 dark:hover:text-lime-400 hover:underline transition-colors">
												{item.url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '')}
											</a>
										) : (
											<span class="text-teal-800 dark:text-teal-100">{item.text}</span>
										)}
									</li>
								);
							})
						}
					</ul>

					<hr class="border-t-2 border-lime-400 my-6 border-dashed" />

					<div id="resume-content" class="text-teal-800 dark:text-teal-300 leading-7">
						<MyResume.Content />
					</div>
				</div>
			</section>
			<button onclick="window.print()" class="fixed bottom-6 right-6 md:bottom-10 md:right-10 z-50 bg-lime-400 dark:bg-teal-800 text-teal-800 dark:text-lime-400 p-4 rounded-full shadow-lg hover:brightness-120 hover:-translate-y-1 transition-all print:hidden flex items-center justify-center cursor-pointer" aria-label="Imprimir ou baixar currículo" title="Baixar currículo">
				<DownloadSimple class="w-7 h-7" />
			</button>
			<footer class="bg-black print:hidden">
				<div class="max-w-6xl m-auto py-6 text-center font-oxygen-mono">
					<div class="text-lime-400 flex items-center justify-center gap-2">
						<span>&copy; {new Date().getFullYear()}</span>
						<span class="inline-block w-5 h-5" style="-webkit-mask: url('/olive-leaf.svg') no-repeat center/contain; mask: url('/olive-leaf.svg') no-repeat center/contain; background-color: currentColor;" aria-hidden="true"></span>
						<span>l4uOliveira</span>
					</div>
				</div>
			</footer>
		</main>
	</body>
</html>
